{
  "info": {
    "_postman_id": "3e7ef658-2b52-4a4a-bf7b-df773f841cb8",
    "name": "Artisan Marketplace API",
    "description": "Postman collection for the production-style artisan marketplace backend. Protected routes use Bearer {{jwtToken}}. Login stores the token automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "description": "Simple health probe for service monitoring.",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Client",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create a client account. Registration requires gender and dateOfBirth.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sara\",\n  \"lastName\": \"Client\",\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\",\n  \"phone\": \"+213555000001\",\n  \"gender\": \"FEMALE\",\n  \"dateOfBirth\": \"1997-05-14\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register/client"
          }
        },
        {
          "name": "Register Worker",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create a worker account. Service specialization is added later through listings, not at registration time. Registration requires gender and dateOfBirth.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Yacine\",\n  \"lastName\": \"Worker\",\n  \"email\": \"{{workerEmail}}\",\n  \"password\": \"{{workerPassword}}\",\n  \"phone\": \"+213555000002\",\n  \"gender\": \"MALE\",\n  \"dateOfBirth\": \"1994-08-23\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register/worker"
          }
        },
        {
          "name": "Register Generic",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Generic registration endpoint when role is provided explicitly. Gender and dateOfBirth are required.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Nadia\",\n  \"lastName\": \"Generic\",\n  \"email\": \"generic@example.com\",\n  \"password\": \"GenericPass123\",\n  \"phone\": \"+213555000003\",\n  \"gender\": \"FEMALE\",\n  \"dateOfBirth\": \"1996-01-30\",\n  \"role\": \"CLIENT\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "  pm.environment.set('jwtToken', json.data.token);",
                  "}",
                  "if (json.success && json.data && json.data.user) {",
                  "  pm.environment.set('userId', json.data.user.id || '');",
                  "  if (json.data.user.workerProfile && json.data.user.workerProfile.id) {",
                  "    pm.environment.set('workerId', json.data.user.workerProfile.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Authenticate and store {{jwtToken}} for later requests.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{workerEmail}}\",\n  \"password\": \"{{workerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "description": "Fetch the authenticated user profile.",
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Update basic client or worker profile fields.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Yacine\",\n  \"lastName\": \"Worker\",\n  \"phone\": \"+213555009999\",\n  \"headline\": \"Trusted artisan\",\n  \"bio\": \"Updated profile bio\",\n  \"yearsExperience\": 7,\n  \"avgResponseMinutes\": 45\n}"
            },
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Taxonomy",
      "item": [
        {
          "name": "Get Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && Array.isArray(json.data) && json.data.length > 0) {",
                  "  pm.environment.set('categoryId', json.data[0].id);",
                  "  if (Array.isArray(json.data[0].subcategories) && json.data[0].subcategories.length > 0) {",
                  "    pm.environment.set('subcategoryId', json.data[0].subcategories[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "description": "Fetch all categories with nested subcategories. Categories and subcategories return imageUrl fields for mobile UI images.",
            "url": "{{baseUrl}}/api/taxonomy/categories"
          }
        },
        {
          "name": "Get Subcategories By Category",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "description": "Fetch subcategories for one category, including imageUrl.",
            "url": "{{baseUrl}}/api/taxonomy/categories/{{categoryId}}/subcategories"
          }
        }
      ]
    },
