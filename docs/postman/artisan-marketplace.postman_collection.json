                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Emergency plumbing repairs",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Leak fixing, pipe replacement, and emergency visits.",
                  "type": "text"
                },
                {
                  "key": "pricingType",
                  "value": "QUOTE",
                  "type": "text"
                },
                {
                  "key": "priceFrom",
                  "value": "2500",
                  "type": "text"
                },
                {
                  "key": "currency",
                  "value": "DZD",
                  "type": "text"
                },
                {
                  "key": "isPublished",
                  "value": "false",
                  "type": "text"
                },
                {
                  "key": "workAreas",
                  "value": "[{\"wilaya\":\"Biskra\",\"commune\":\"Doucen\"}]",
                  "type": "text"
                },
                {
                  "key": "availabilityRules",
                  "value": "[{\"dayOfWeek\":1,\"startTime\":\"09:00\",\"endTime\":\"17:00\",\"slotDurationMinutes\":60,\"isActive\":true}]",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/api/listings"
